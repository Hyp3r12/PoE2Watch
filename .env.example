# Main Discord channel where sale notification cards are posted.
DISCORD_WEBHOOK_URL=

# Optional comma-separated extra webhook destinations for mirrored sale notifications.
DISCORD_WEBHOOK_URLS=

# Your Path of Exile session cookie and league name.
# Treat POE_COOKIE like a password.
# Include the cookie name and value, not only the alphanumeric value.
# Fake example: POE_COOKIE=POESESSID=example_fake_session_value_here
POE_COOKIE=
POE_LEAGUE=Runes of Aldur

# Discord bot application values used for slash commands.
# DISCORD_CLIENT_ID is the Discord application ID.
# DISCORD_GUILD_ID is your Discord server ID.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Optional comma-separated Discord user IDs allowed to use /dev commands.
# Server administrators can also use /dev commands.
DISCORD_DEV_USER_IDS=

# Optional public image URL for webhook avatar branding.
# Defaults to https://poe2watch.app/assets/project-logo.png when empty.
POE2WATCH_LOGO_URL=

# Third-party estimates from poe.ninja. Not official GGG data.
POE_RATE_PROVIDER=poe-ninja
POE_NINJA_LEAGUE_NAME=Runes of Aldur
POE_NINJA_LEAGUE_SLUG=runesofaldur
POE_NINJA_CURRENCY_API_URL=

# Placeholder only. Do not use until GGG OAuth/app registration is confirmed.
# Exchange estimates are experimental and disabled unless this is explicitly true.
POE_EXPERIMENTAL_OAUTH_EXCHANGE=false
POE_OAUTH_TOKEN=
POE_OAUTH_CLIENT_ID=
POE_CONTACT_EMAIL=
